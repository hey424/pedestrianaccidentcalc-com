---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | pedestrianaccidentcalc.com';
const description = 'Contact the editorial team at pedestrianaccidentcalc.com for corrections, feedback, or questions.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>For corrections, feedback, or questions about the calculator or guides, email the editorial team at <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <h2>What We Can Help With</h2>
  <p>We respond to: factual corrections (incorrect state fault rules, outdated insurance minimums, multiplier errors — include the specific claim and your source); feedback on calculator or guide content; and questions about methodology or editorial standards.</p>

  <h2>What We Cannot Help With</h2>
  <p>We cannot provide legal advice, evaluate your specific claim, or advise on whether you should accept a settlement offer. For case-specific advice, consult a licensed personal injury attorney — most pedestrian accident attorneys offer free initial consultations and work on contingency.</p>

  <h2>Response Time</h2>
  <p>We aim to respond to factual corrections within five business days. We cannot guarantee responses to every message.</p>

  <p>Return to the <a href="/">calculator</a> or see the <a href="/about">about page</a>.</p>
</BaseLayout>
